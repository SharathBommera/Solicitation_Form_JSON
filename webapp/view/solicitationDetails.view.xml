<mvc:View
	xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns:form="sap.ui.layout.form"
	xmlns="sap.m"
	xmlns:layout="sap.ui.layout"
	xmlns:uxap="sap.uxap"
	xmlns:core="sap.ui.core"
    controllerName="solireq.solicitationreq.controller.solicitationDetails"
    height="100%">
	<Page id="_IDGenPage" showHeader="false">
		<uxap:ObjectPageLayout id="_IDGenObjectPageLayout">
			<uxap:headerTitle>
				<uxap:ObjectPageDynamicHeaderTitle id="_IDGenObjectPageDynamicHeaderTitle1">
					<uxap:actions>
						<Button id="_IDGenButton31" text="Edit" type="Emphasized" icon="sap-icon://edit" visible="{solireq>/visibleEdit}" press=".onEdit"/>
						<Button id="_IDGenButton1" text="Print" type="Emphasized" icon="sap-icon://print" visible="{solireq>/enableButton1}"/>
						<Button id="_IDGenButton4" text="Order" type="Emphasized" icon="sap-icon://save" visible="{solireq>/enableButton1}"/>
						<Button id="_IDGenButton2" text="Save" type="Emphasized" icon="sap-icon://save" visible="{solireq>/enableButton2}" press=".onSave"/>
						<Button id="_IDGenButton5" text="Cancel" type="Emphasized" icon="sap-icon://cancel" visible="{solireq>/enableButton2}" press=".onCancel"/>
					</uxap:actions>
				</uxap:ObjectPageDynamicHeaderTitle>
			</uxap:headerTitle>
			<uxap:sections>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection1" title="Basic Data" >
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection">
							<uxap:blocks>
								<VBox id="_IDGenVBox" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleFormUnified" width="100%" layout="ResponsiveGridLayout"
                                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                        emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                                        columnsXL="2" columnsL="2" columnsM="2"
                                        editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle1"/>
											<Label id="_IDGenLabel11" text="Solicitation Title" required="true"/>
											<Input id="_IDGenInput5" value="{solireq>/currentRow/outTitle}" maxLength="15" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel811" text="Date" required="true"/>
											<DatePicker id="_IDGenDatePicker1"
                                                value="{path: 'solireq>/currentRow/outDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}"
                                                displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel51" text="Solicitation Type" required="true"/>
											<Select id="_IDGenSelect" selectedKey="{solireq>/currentRow/outType}" editable="{solireq>/editMode}" items="{path: 'srODataModel>/srtypeSet'}">
												<core:Item id="_IDGenItemType" key="{srODataModel>SBTypeId}" text="{srODataModel>STypeDesc}"/>
											</Select>
											<Label id="_IDGenLabel41" text="Solicitation Number" required="true"/>
											<Input id="_IDGenInput7" value="{solireq>/currentRow/outNumber}" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel8111" text="Proposed Due Date" required="true"/>
											<DatePicker id="_IDGenDatePicker11"
                                                value="{path: 'solireq>/currentRow/outDueDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}"
                                                displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{solireq>/editMode}"/>
											<core:Title id="_IDGenTitle2"/>
											<Label id="_IDGenLabel4111" text="From" required="true"/>
											<Input id="_IDGenInput711" value="{solireq>/currentRow/outFrom}" showValueHelp="{solireq>/editMode}" valueHelpRequest=".handleValueHelp1" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel411" text="Department" required="true"/>
											<Select id="_IDGenSelectDept" selectedKey="{solireq>/currentRow/outDepartment}" editable="{solireq>/editMode}" items="{path: 'srODataModel>/srdeptSet'}">
												<core:Item id="_IDGenItemDept" key="{srODataModel>SBDeptId}" text="{srODataModel>SDeptDesc}"/>
											</Select>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection2" title="MANDATORY MEETING/JOBWALK">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection1">
							<uxap:blocks>
								<VBox id="_IDGenVBox1" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleFormUnified1" width="100%" layout="ResponsiveGridLayout"
                                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                        emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                                        columnsXL="2" columnsL="2" columnsM="2"
                                        editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle3"/>
											<Label id="_IDGenLabel42" text="Mandatory Meeting" required="true"/>
											<HBox id="_IDGenHBoxMandatoryMeeting" columnGap="4rem">
												<RadioButtonGroup id="GroupA" columns="2" editable="{solireq>/editMode}" select=".onMandatoryMeetingSelect" selectedIndex="{solireq>/currentRow/outMandatoryMeeting}">
													<RadioButton id="_IDGenRadioButton" text="No"/>
													<RadioButton id="_IDGenRadioButton1" text="Yes"/>
												</RadioButtonGroup>
												<HBox id="_IDGenHBox" columnGap="2rem">
													<CheckBox id="_IDGenCheckWebex" text="Webex" selected="{solireq>/currentRow/outWebex}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/manMeet} === true }"/>
													<CheckBox id="_IDGenCheckInPerson" text="In-Person" selected="{solireq>/currentRow/outInPerson}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/manMeet} === true }"/>
												</HBox>
											</HBox>
											<Label id="_IDGenLabel421" text="Has Room Been Reserved?" required="true"/>
											<RadioButtonGroup id="GroupB" columns="2" editable="{solireq>/editMode}" select=".onRoomReservedSelect" selectedIndex="{solireq>/currentRow/outRoomReserved}">
												<RadioButton id="_IDGenRadioButton123" text="No"/>
												<RadioButton id="_IDGenRadioButton12" text="Yes"/>
											</RadioButtonGroup>
											<Label id="_IDGenLabel4211" text="Location"/>
											<TextArea id="_IDGenTextArea" rows="4" value="{solireq>/currentRow/outLocation1}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/roomRes} === true }"/>
											<core:Title id="_IDGenTitle4"/>
											<Label id="_IDGenLabel1" text="Proposed Date"/>
											<DatePicker id="_IDGenDatePicker3" value="{path: 'solireq>/currentRow/outDate1', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}" displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel10" text="Time"/>
											<TimePicker id="_IDGenTimePicker" value="{path: 'solireq>/currentRow/outTime1', type: 'sap.ui.model.odata.type.Time', formatOptions: {pattern: 'HH:mm:ss'}}" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel12" text="Zone"/>
											<Input id="_IDGenInput2" value="{solireq>/currentRow/outZone}" editable="{solireq>/editMode}"/>
											<core:Title id="_IDGenTitle5"/>
											<Label id="_IDGenLabel4213" text="Jobsite Walk" required="true"/>
											<RadioButtonGroup id="GroupC" columns="2" editable="{solireq>/editMode}" select=".onJobsiteWalkSelect" selectedIndex="{solireq>/currentRow/outJobsiteWalk}">
												<RadioButton id="_IDGenRadioButton1234" text="No"/>
												<RadioButton id="_IDGenRadioButton12345" text="Yes"/>
											</RadioButtonGroup>
											<Label id="_IDGenLabel112" text="Proposed Date"/>
											<DatePicker id="_IDGenDatePicker4" value="{path: 'solireq>/currentRow/outDate2', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}" displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/jobWalkReq} === true }"/>
											<Label id="_IDGenLabel1123" text="Time"/>
											<TimePicker id="_IDGenTimePicker1" value="{path: 'solireq>/currentRow/outTime2', type: 'sap.ui.model.odata.type.Time', formatOptions: {pattern: 'HH:mm:ss'}}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/jobWalkReq} === true }"/>
											<Label id="_IDGenLabel13" text="Location"/>
											<TextArea id="_IDGenTextArea1" value="{solireq>/currentRow/outLocation2}" rows="4" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/jobWalkReq} === true }"/>
											<core:Title id="_IDGenTitle6"/>
											<Label id="_IDGenLabel14" text="PPE Required" required="true"/>
											<RadioButtonGroup id="GroupD" columns="2" editable="{solireq>/editMode}" selectedIndex="{solireq>/currentRow/outPpeRequired}">
												<RadioButton id="_IDGenRadioButton2" text="No"/>
												<RadioButton id="_IDGenRadioButton3" text="Yes"/>
											</RadioButtonGroup>
											<Label id="_IDGenLabel15" text="Special Instructions"/>
											<TextArea id="_IDGenTextArea2" value="{solireq>/currentRow/outSpecialInstr}" rows="4" editable="{solireq>/editMode}"/>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection3" title="Solicitation Category">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection2">
							<uxap:blocks>
								<VBox id="_IDGenVBox12" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleFormUnified12" width="100%" layout="ResponsiveGridLayout" editable="{solireq>/editMode}">
										<form:content>
											<VBox id="_IDGenVBox3">
												<CheckBox id="_IDGenCheckBox1" text="Engineering Services" selected="{solireq>/currentRow/outCatEng}" editable="{solireq>/editMode}"/>
												<CheckBox id="_IDGenCheckBox2" text="IT/OT (Software or Network Connected)" selected="{solireq>/currentRow/outCatIT}" editable="{solireq>/editMode}"/>
												<CheckBox id="_IDGenCheckBox3" text="Materials" selected="{solireq>/currentRow/outCatMat}" editable="{solireq>/editMode}"/>
												<CheckBox id="_IDGenCheckBox4" text="Construction Services" selected="{solireq>/currentRow/outCatConst}" editable="{solireq>/editMode}"/>
												<CheckBox id="_IDGenCheckBox5" text="Professional Services" selected="{solireq>/currentRow/outCatProf}" editable="{solireq>/editMode}"/>
												<CheckBox id="_IDGenCheckBox6" text="Other (define below)" select=".onSoliCatOtherSelect" selected="{solireq>/currentRow/outCatOther}" editable="{solireq>/editMode}"/>
												<Input id="_IDGenInput3" value="{solireq>/currentRow/outCatOtherTxt}" width="50%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/soliCatOther} === true}"/>
											</VBox>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection4" title="Contractor's License">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection3">
							<uxap:blocks>
								<VBox id="_IDGenVBox11" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleForm" width="100%" layout="ResponsiveGridLayout" editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle7"/>
											<VBox id="_IDGenVBox4">
												<HBox id="_IDGenHBox1" columnGap="6rem">
													<Label id="_IDGenLabel" text="Will a Contractor's license be required for this work?"/>
													<RadioButtonGroup id="_IDGenRadioButtonGroup" columns="2" editable="{solireq>/editMode}" select=".onContractorSelect" selectedIndex="{solireq>/currentRow/outContractorReq}">
														<RadioButton id="_IDGenRadioButton4" text="No"/>
														<RadioButton id="_IDGenRadioButton5" text="Yes"/>
													</RadioButtonGroup>
												</HBox>
												<CheckBox id="_IDGenCheckBox" text="A - General Engineering Contractor" selected="{solireq>/currentRow/outLicenseA}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true }"/>
												<CheckBox id="_IDGenCheckBox7" text="B - General Building Contractor" selected="{solireq>/currentRow/outLicenseB}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true }"/>
												<HBox id="_IDGenHBox2" columnGap="3rem">
													<CheckBox id="_IDGenCheckBox8" text="C - Speciality Contractor" select=".onSpecialityContractorSelect" selected="{solireq>/currentRow/outLicenseC}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true }"/>
													<HBox id="_IDGenHBox3" alignItems="Center">
														<Text id="_IDGenLabel2" text="If you designate a type 'C', you must enter the speciality&#xA;contractor number:"/>
														<VBox id="_IDGenVBox13">
															<Input id="_IDGenInput4" value="{solireq>/currentRow/outLicenseCTxt}" width="50%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true &amp;&amp; ${solireq>/speCon} === true}"/>
															<Link id="_IDGenLink" text="https://www.cslb.ca.gov/About_Us/Library/Licensing_Classifications/" target="_blank" href="https://www.cslb.ca.gov/About_Us/Library/Licensing_Classifications/"/>
														</VBox>
													</HBox>
												</HBox>
												<HBox id="_IDGenHBox4" columnGap="3rem">
													<CheckBox id="_IDGenCheckBox9" text="C61 - Limited Speciality Classification" select=".onLimitedSpecialityClassificationSelect" selected="{solireq>/currentRow/outLicenseC61}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true }"/>
													<HBox id="_IDGenHBox5" alignItems="Center">
														<Text id="_IDGenLabel3" text="If you designate a type 'C61', you must enter the 'D' subcategory number:"/>
														<VBox id="_IDGenVBox14">
															<Input id="_IDGenInput6" value="{solireq>/currentRow/outLicenseC61Txt}" width="50%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true &amp;&amp; ${solireq>/limSpeClass} === true}"/>
															<Link id="_IDGenLink1" text="https://www.cslb.ca.gov/About_Us/Library/Licensing_Classifications/C-61_Limited_Specialty/Default.aspx" target="_blank" href="https://www.cslb.ca.gov/About_Us/Library/Licensing_Classifications/C-61_Limited_Specialty/Default.aspx"/>
														</VBox>
													</HBox>
												</HBox>
												<HBox id="_IDGenHBox6">
													<CheckBox id="_IDGenCheckBox10" text="Other" select=".onOtherLicenseSelect" selected="{solireq>/currentRow/outLicenseOther}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true }"/>
													<Input id="_IDGenInput8" value="{solireq>/currentRow/outLicenseOtherTxt}" width="40%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/contractorReq} === true &amp;&amp; ${solireq>/licenseOther} === true}"/>
												</HBox>
											</VBox>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection5" title="Project Details">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection4">
							<uxap:blocks>
								<VBox id="_IDGenVBox15" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleForm1" width="100%" layout="ResponsiveGridLayout"
                                        labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                        emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                                        columnsXL="2" columnsL="2" columnsM="2"
                                        editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle"/>
											<Text id="_IDGenLabel162" text="What is the expected timeline of the resulting contract?"/>
											<Label id="_IDGenLabel16" text="Begin" required="true"/>
											<DatePicker id="_IDGenDatePicker"
                                                value="{path: 'solireq>/currentRow/outBegin', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}"
                                                displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{solireq>/editMode}"/>
											<Label id="_IDGenLabel17" text="Will prevailing wages be required?" required="true"/>
											<RadioButtonGroup id="_IDGenRadioButtonGroup1" columns="2" editable="{solireq>/editMode}" selectedIndex="{solireq>/currentRow/outPrevailingWages}">
												<RadioButton id="_IDGenRadioButton6" text="No"/>
												<RadioButton id="_IDGenRadioButton7" text="Yes"/>
											</RadioButtonGroup>
											<Label id="_IDGenLabel18" text="Will a bid bond be required?" required="true"/>
											<RadioButtonGroup id="_IDGenRadioButtonGroup2" columns="2" editable="{solireq>/editMode}" selectedIndex="{solireq>/currentRow/outBidBond}">
												<RadioButton id="_IDGenRadioButton8" text="No"/>
												<RadioButton id="_IDGenRadioButton9" text="Yes"/>
											</RadioButtonGroup>
											<Label id="_IDGenLabel19" text="What is the estimated value of the contract award?" required="true"/>
											<Input id="_IDGenInput9" value="{solireq>/currentRow/outEstValue}" editable="{solireq>/editMode}"/>
											<core:Title id="_IDGenTitle8"/>
											<Text id="_IDGenText" text="&#xA;"/>
											<Label id="_IDGenLabel20" text="End" required="true"/>
											<DatePicker id="_IDGenDatePicker2"
                                                value="{path: 'solireq>/currentRow/outEnd', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'MM/dd/yyyy', UTC: true}}"
                                                displayFormat="MM/dd/yyyy" valueFormat="MM/dd/yyyy" editable="{solireq>/editMode}"/>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection6" title="Funding Source/Other Federal Requirements">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection5">
							<uxap:blocks>
								<VBox id="_IDGenVBox5" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleForm2" width="100%" layout="ResponsiveGridLayout" editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle9"/>
											<VBox id="_IDGenVBox6">
												<HBox id="_IDGenHBox11">
													<Label id="_IDGenLabel21" text="Has this project and budget been approved?"/>
													<RadioButtonGroup id="_IDGenRadioButtonGroup3" columns="2" editable="{solireq>/editMode}" select=".onBudgetApprSelect" selectedIndex="{solireq>/currentRow/outBudgetAppr}">
														<RadioButton id="_IDGenRadioButton10" text="No"/>
														<RadioButton id="_IDGenRadioButton11" text="Yes"/>
													</RadioButtonGroup>
												</HBox>
												<HBox id="_IDGenHBox12">
													<Label id="_IDGenLabel22" text='If "No", please clarify'/>
													<TextArea id="_IDGenTextArea3" value="{solireq>/currentRow/outBudgetApprNo}" rows="2" width="100%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/budgetApprNo} === true }"/>
												</HBox>
												<CheckBox id="_IDGenCheckBox11" text="IID Revenues" selected="{solireq>/currentRow/outFundIID}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/budgetApprNo} === true }"/>
												<CheckBox id="_IDGenCheckBox12" text="Federal Funding" select=".onFundFedSelect" selected="{solireq>/currentRow/outFundFed}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/budgetApprNo} === true }"/>
												<HBox id="_IDGenHBox13">
													<Label id="_IDGenLabel23" text='If materials are involved, is this purchase subject to the "Buy America Act"?'/>
													<RadioButtonGroup id="_IDGenRadioButtonGroup4" columns="2" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/buyAmericaAct} === true }" selectedIndex="{solireq>/currentRow/outBuyAmerica}">
														<RadioButton id="_IDGenRadioButton13" text="No"/>
														<RadioButton id="_IDGenRadioButton14" text="Yes"/>
													</RadioButtonGroup>
												</HBox>
												<CheckBox id="_IDGenCheckBox13" text="State of California Funding" selected="{solireq>/currentRow/outFundState}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/budgetApprNo} === true }"/>
												<CheckBox id="_IDGenCheckBox14" text="Other Funding Sources" select=".onFundOtherSelect" selected="{solireq>/currentRow/outFundOther}" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/budgetApprNo} === true }"/>
												<HBox id="_IDGenHBox14">
													<Label id="_IDGenLabel24" text="Identify the program, contract or other funding source"/>
													<TextArea id="_IDGenTextArea5" value="{solireq>/currentRow/outFundOtherTxt}" rows="2" width="100%" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/fundOther} === true }"/>
												</HBox>
												<Label id="_IDGenLabel25" text="Also, please attach any documentation relevant to the federal or state funds to be obtained."/>
											</VBox>
											<core:Title id="_IDGenTitle10"/>
										</form:content>
									</form:SimpleForm>
								</VBox>
							</uxap:blocks>
						</uxap:ObjectPageSubSection>
					</uxap:subSections>
				</uxap:ObjectPageSection>
				<uxap:ObjectPageSection id="_IDGenObjectPageSection7" title="Regulatory/Compliance">
					<uxap:subSections>
						<uxap:ObjectPageSubSection id="_IDGenObjectPageSubSection6">
							<uxap:blocks>
								<VBox id="_IDGenVBox7" class="sapUiContentPadding">
									<form:SimpleForm id="_IDGenSimpleForm3" width="100%" layout="ResponsiveGridLayout" editable="{solireq>/editMode}">
										<form:content>
											<core:Title id="_IDGenTitle11"/>
											<VBox id="_IDGenVBox21">
												<Label id="_IDGenLabel5" text="Is this solicitation subject to any of the following regulatory/compliance requirements?"/>
												<HBox id="_IDGenHBox16" alignItems="Center">
													<Label id="_IDGenLabel6" text="NERC - CIP-013 Standard"/>
													<HBox id="_IDGenHBox17" columnGap="5rem">
														<RadioButtonGroup id="_IDGenRadioButtonGroup6" columns="2" editable="{solireq>/editMode}" select=".onNercSelect" selectedIndex="{solireq>/currentRow/outRegNERC}">
															<RadioButton id="_IDGenRadioButton17" text="No"/>
															<RadioButton id="_IDGenRadioButton18" text="Yes"/>
														</RadioButtonGroup>
														<HBox id="_IDGenHBox18" alignItems="End">
															<Input id="_IDGenInput10" value="{solireq>/currentRow/outRegNERCTxt}" width="10rem" editable="{= ${solireq>/editMode} === true &amp;&amp; ${solireq>/regNERC} === true }"/>
															<Label id="_IDGenLabel26" text="Provide Certification Number"/>
														</HBox>
													</HBox>
												</HBox>
												<HBox id="_IDGenHBox19">
													<Label id="_IDGenLabel27" text="Executive Order Number"/>
													<HBox id="_IDGenHBox20" columnGap="6rem">
														<RadioButtonGroup id="_IDGenRadioButtonGroup7" columns="2" editable="{solireq>/editMode}" select=".onExecSelect" selectedIndex="{solireq>/currentRow/outRegExec}">
															<RadioButton id="_IDGenRadioButton19" text="No"/>
